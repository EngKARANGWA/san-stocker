# Neon Postgres connection strings
# DATABASE_URL: pooled connection (used by the app at runtime)
# DIRECT_URL: direct connection (used by Prisma Migrate)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# App
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# Platform Super Admin (SAN TECH) seed account
SUPER_ADMIN_EMAIL=superadmin@santech.com
SUPER_ADMIN_PHONE=
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_FIRST_NAME=SAN
SUPER_ADMIN_LAST_NAME=TECH

# "Continue with Google" sign-in (optional). Comma-separated OAuth 2.0 client
# IDs (web/Android/iOS) from https://console.cloud.google.com/apis/credentials
# that are accepted as audiences for Google ID tokens. Leave empty to disable.
GOOGLE_CLIENT_IDS=
